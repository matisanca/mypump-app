# Cloudflare Pages — Routing

# Landing page
/                  /index.html       200

# CF Pages hace 301 automático: /cliente.html → /cliente ("Clean URLs")
# Esta regla intercepta ese destino ANTES de que lo atrape /:token
/cliente           /cliente.html     200

# Archivos estáticos directos (no redirect)
/cliente.html      /cliente.html     200
/css/*             /css/:splat       200
/js/*              /js/:splat        200
/assets/*          /assets/:splat    200

# Tokens de cliente (catch-all SOLO para paths sin extensión)
/:token            /cliente.html     200
